# =====================================================================
# VenTune — voorbeeld-omgevingsbestand
# Kopieer dit bestand naar `.env` en vul de waarden in:
#   cp .env.example .env
# Het echte `.env`-bestand hoort NIET in git (staat in .gitignore).
# =====================================================================

# ---------------------------------------------------------------------
# Algemeen
# ---------------------------------------------------------------------
# De publieke URL waarop VenTune bereikbaar is via de Cloudflare-tunnel.
# Wordt gebruikt voor QR-codes, join-links en de Spotify redirect.
APP_URL=https://ventune.ventrex.cc

# Draaiomgeving: development of production
NODE_ENV=production

# ---------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------
POSTGRES_USER=ventune
POSTGRES_PASSWORD=verander_dit_wachtwoord
POSTGRES_DB=ventune

# Volledige connectie-URL die de server gebruikt.
# Host is de servicenaam 'db' binnen het Docker-netwerk.
DATABASE_URL=postgres://ventune:verander_dit_wachtwoord@db:5432/ventune

# ---------------------------------------------------------------------
# Server (backend)
# ---------------------------------------------------------------------
# Interne poort waarop de Node-server luistert (binnen de container).
PORT=3000

# Geheime sleutel voor het ondertekenen van sessie-tokens.
# Genereer bijv. met: openssl rand -hex 32
SESSION_SECRET=verander_dit_naar_een_lange_willekeurige_reeks

# ---------------------------------------------------------------------
# Muziek (iTunes Search API)
# ---------------------------------------------------------------------
# Geen key, geen account, geen registratie nodig. De iTunes Search API is
# gratis en levert 30-seconden preview-clips. Deze variabele bepaalt in
# welke landstore gezocht wordt; NL geeft betere dekking voor Nederlandse
# titels. Laat op 'NL' staan tenzij je een andere store wilt.
ITUNES_LAND=NL

# ---------------------------------------------------------------------
# TMDB (alleen server-side — gratis key)
# ---------------------------------------------------------------------
# Gratis API-key aanvragen op https://www.themoviedb.org/settings/api
TMDB_API_KEY=vul_hier_je_tmdb_key_in

# ---------------------------------------------------------------------
# Admin-portal (/admin)
# ---------------------------------------------------------------------
# Wachtwoord voor toegang tot het beheerportaal.
ADMIN_PASSWORD=verander_dit_admin_wachtwoord

# ---------------------------------------------------------------------
# Discord-webhook (OPTIONEEL)
# ---------------------------------------------------------------------
# Voor operationele meldingen (crash, DB-fout, nieuwe lobby).
# Laat leeg om meldingen uit te schakelen — de app werkt ook zonder.
DISCORD_WEBHOOK_URL=

# ---------------------------------------------------------------------
# Client (frontend) — Vite build-tijd variabelen
# ---------------------------------------------------------------------
# Deze worden tijdens de build in de client gebakken.
VITE_APP_URL=https://ventune.ventrex.cc
